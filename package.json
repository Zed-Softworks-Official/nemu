{
    "name": "nemu",
    "private": true,
    "license": "Apache-2.0",
    "scripts": {
        "dev": "bash scripts/dev.sh",
        "dev:web": "bash scripts/kill-dev-ports.sh && turbo run dev --filter=@nemu/web --filter=@nemu/dashboard --filter=@nemu/docs",
        "dev:dashboard": "bash scripts/kill-dev-ports.sh && turbo run dev --filter=@nemu/dashboard",
        "convex:dev": "turbo run convex:dev",
        "build": "turbo run build --filter=@nemu/web --filter=@nemu/dashboard",
        "build:web": "pnpm --filter @nemu/cloud exec convex deploy --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL --cmd 'cd ../.. && turbo run build --filter=@nemu/web'",
        "build:dashboard": "turbo run build --filter=@nemu/dashboard",
        "build:rust": "turbo run build:rust",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check-types": "turbo run check-types",
        "infra": "docker compose -f docker-compose.dev.yml up -d",
        "infra:down": "docker compose -f docker-compose.dev.yml down",
        "db:migrate": "pnpm --filter @nemu/core db:migrate",
        "db:revert": "pnpm --filter @nemu/core db:revert",
        "db:new": "pnpm --filter @nemu/core db:new",
        "db:reset": "pnpm --filter @nemu/core db:reset",
        "db:setup": "pnpm --filter @nemu/core db:setup",
        "ui-add": "turbo run ui-add --filter=@nemu/ui --"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.8",
        "@nemu/biome-config": "workspace:*",
        "dotenv-cli": "^11.0.0",
        "prettier": "^3.6.2",
        "turbo": "^2.10.5",
        "typescript": "5.9.2"
    },
    "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578",
    "engines": {
        "node": ">=18"
    }
}
