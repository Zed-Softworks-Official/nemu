{
    "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
    "root": false,
    "vcs": {
        "enabled": true,
        "useIgnoreFile": true,
        "clientKind": "git"
    },
    "assist": {
        "enabled": true,
        "actions": {
            "recommended": true,
            "source": {
                "recommended": true,
                "organizeImports": "on",
                "useSortedAttributes": "on"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "lineWidth": 80,
        "indentWidth": 4,
        "indentStyle": "space"
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "nursery": {
                "useSortedClasses": {
                    "level": "warn",
                    "fix": "safe",
                    "options": {
                        "functions": ["clsx", "cva", "cn"]
                    }
                }
            }
        }
    },
    "html": {
        "formatter": {
            "enabled": true
        }
    },
    "javascript": {
        "assist": {
            "enabled": true
        },
        "formatter": {
            "enabled": true,
            "quoteStyle": "single",
            "trailingCommas": "es5",
            "semicolons": "asNeeded"
        },
        "linter": {
            "enabled": true
        }
    },
    "css": {
        "assist": {
            "enabled": true
        },
        "formatter": {
            "enabled": true
        },
        "linter": {
            "enabled": true
        },
        "parser": {
            "cssModules": true,
            "tailwindDirectives": true
        }
    }
}
