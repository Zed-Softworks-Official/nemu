{
    "name": "@nemu/web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "check": "biome check .",
        "check:unsafe": "biome check --write --unsafe .",
        "check:write": "biome check --write .",
        "dev": "MFE_DISABLE_LOCAL_PROXY_REWRITE=1 pnpm with-env next dev --turbo --port $(pnpm exec microfrontends port)",
        "preview": "next build && next start",
        "start": "next start",
        "typecheck": "tsc --noEmit",
        "with-env": "dotenv -e ../../.env --"
    },
    "dependencies": {
        "@clerk/nextjs": "catalog:",
        "@clerk/ui": "catalog:",
        "@nemu/ui": "workspace:*",
        "@t3-oss/env-nextjs": "^0.12.0",
        "@vercel/microfrontends": "catalog:",
        "lucide-react": "^1.23.0",
        "motion": "^12.42.2",
        "next": "catalog:",
        "next-themes": "^0.4.6",
        "react": "catalog:",
        "react-dom": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.8",
        "@nemu/biome-config": "workspace:*",
        "@nemu/typescript-config": "workspace:*",
        "@tailwindcss/postcss": "^4.0.15",
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "postcss": "^8.5.3",
        "tailwindcss": "^4.0.15",
        "typescript": "catalog:"
    },
    "ct3aMetadata": {
        "initVersion": "7.40.0"
    },
