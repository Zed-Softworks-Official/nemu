{
    "$schema": "https://turborepo.dev/microfrontends/schema.json",
    "options": {
        "localProxyPort": 3024
    },
    "applications": {
        "nemu-web": {
            "packageName": "@nemu/web",
            "development": {
                "local": 3000
            }
        },
        "nemu-dashboard": {
            "packageName": "@nemu/dashboard",
            "development": {
                "local": 3001
            },
            "routing": [
                {
                    "paths": ["/dashboard", "/dashboard/:path*"]
                }
            ]
        }
    }
}
