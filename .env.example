# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# Clerk (apps/web)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex (apps/web + packages/cloud)
# After `pnpm --filter @nemu/cloud dev`, copy CONVEX_URL from packages/cloud/.env.local
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Convex dashboard / local backend (packages/cloud)
CLERK_JWT_ISSUER_DOMAIN=
# Optional: shared secret for controller registration + relay respond
CONTROLLER_REGISTRATION_SECRET=
