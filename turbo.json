{
    "$schema": "https://v2-10-5.turborepo.dev/schema.json",
    "ui": "tui",
    "globalEnv": ["NODE_ENV"],
    "globalPassThroughEnv": [
        "CI",
        "VERCEL",
        "VERCEL_*",
        "VERCEL_GIT_*",
        "TURBO_*",
        "CONVEX_DEPLOY_KEY"
    ],
    "tasks": {
        "build": {
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"],
            "env": [
                "NEXT_PUBLIC_CONVEX_URL",
                "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
                "CLERK_SECRET_KEY"
            ]
        },
        "build:rust": {
            "cache": false,
            "outputs": ["target/**"]
        },
        "convex:deploy": {
            "cache": false,
            "env": ["CONVEX_DEPLOY_KEY", "CLERK_JWT_ISSUER_DOMAIN"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "dev:web": {
            "cache": false,
            "persistent": true
        },
        "convex:dev": {
            "cache": false,
            "persistent": true
        },
        "//#infra": {
            "cache": false
        }
    }
}
