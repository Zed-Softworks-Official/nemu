# ═══════════════════════════════════════════════════════════════════════════════
# OS
# ═══════════════════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════════════════════════════
# Environment
# ═══════════════════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
!.env.example
!core/.env.example
!web/.env.example

# ═══════════════════════════════════════════════════════════════════════════════
# Rust (core/)
# ═══════════════════════════════════════════════════════════════════════════════
target/
**/*.rs.bk

# ═══════════════════════════════════════════════════════════════════════════════
# Node / Next.js (web/)
# ═══════════════════════════════════════════════════════════════════════════════
node_modules/
/web/.next/
/web/out/
/web/.turbo/
*.tsbuildinfo
.npm
.pnpm-store/

# ═══════════════════════════════════════════════════════════════════════════════
# Build outputs
# ═══════════════════════════════════════════════════════════════════════════════
/dist/
/build/

# ═══════════════════════════════════════════════════════════════════════════════
# Docker
# ═══════════════════════════════════════════════════════════════════════════════
docker-compose.override.yml

# ═══════════════════════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════════════════════
*.sql
!infra/postgres/init.sql
!/apps/core/migrations/**/*.sql

# ═══════════════════════════════════════════════════════════════════════════════
# Backups
# ═══════════════════════════════════════════════════════════════════════════════
/backups/

# ═══════════════════════════════════════════════════════════════════════════════
# IDE
# ═══════════════════════════════════════════════════════════════════════════════
.idea/
.vscode/
*.iml

# ═══════════════════════════════════════════════════════════════════════════════
# Testing / Coverage
# ═══════════════════════════════════════════════════════════════════════════════
coverage/
.nyc_output/
*.lcov

# ═══════════════════════════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════════════════════════
*.log
logs/

# ═══════════════════════════════════════════════════════════════════════════════
# Zigbee2MQTT (local dev data)
# ═══════════════════════════════════════════════════════════════════════════════
/infra/zigbee2mqtt/coordinator_backup.json
/infra/zigbee2mqtt/database.db
/infra/zigbee2mqtt/state.json
/infra/zigbee2mqtt/devices.yaml
/infra/zigbee2mqtt/groups.yaml
/infra/zigbee2mqtt/configuration_backup*.yaml
!infra/zigbee2mqtt/configuration.yaml

# ═══════════════════════════════════════════════════════════════════════════════
# Mosquitto (local dev data)
# ═══════════════════════════════════════════════════════════════════════════════
/infra/mosquitto/*.db
/infra/mosquitto/passwd
!infra/mosquitto/mosquitto.conf
!infra/mosquitto/acl.conf
